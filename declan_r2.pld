Name       declan_r2.pld;
Partno     ;
Date       ;
Revision   ;
Designer   ;
Company    ;
Assembly   ;
Location   ;
Device     G16V8;

PIN 1 = RGA3;
PIN 2 = RGA4;
PIN 3 = RGA5;
PIN 4 = RGA6;
PIN 5 = RGA7;
PIN 6 = RGA8;
PIN 7 = RGA2;
PIN 8 = CCKQ;
PIN 9 = CCK;

PIN 18 = RGA1;
PIN 17 = !BUSDATA_CLK_n;
PIN 16 = !PAULA_BUSDIR_n;
PIN 15 = PAULA_BUSOE;
PIN 14 = !SERDAT_WRITTEN_n;
PIN 13 = !SERDATR_READ_n;
PIN 12 = !SERPER_WRITTEN_n;
//PIN 11 = !RESET;

FIELD ADDRESS = [RGA8, RGA7, RGA6, RGA5, RGA4, RGA3, RGA2, RGA1];

// Clock phases for the bus DMA slot, same as are generated within Paula.
P1 = CCK & !CCKQ;	   // Address stabilizing and stable at transition to P2. Data going away after short hold time.
P2 = CCK & CCKQ;     // Address stable during whole phase. For DSKDATR this is an early-read slot, and data is stable at transition to P3.
P3 = !CCK & CCKQ;    // Address going away now. Data stabilizing (for DSKDATR remains stable?).
P4 = !CCK & !CCKQ;   // Data stable at transition to P1.

// Read-only registers (all of them)
DSKDATR_MATCH = ADDRESS:08;
ADKCONR_MATCH = ADDRESS:10;
POT0DAT_MATCH = ADDRESS:12;
POT1DAT_MATCH = ADDRESS:14;
POTINP_MATCH = ADDRESS:16;
SERDATR_MATCH = ADDRESS:18;
DSKBYTR_MATCH = ADDRESS:1A;
INTENAR_MATCH= ADDRESS:1C;
INTREQR_MATCH = ADDRESS:1E;

// Write-only registers (only a couple of them)
SERDAT_MATCH = ADDRESS:30;
SERPER_MATCH = ADDRESS:32;

// "Null" register when nothing is being addressed
IDLE_MATCH = ADDRESS:1FE;

// Clock signal for the pair of 574s capturing bus data for the MCU.
// Note that this is inverted and we pull the line to 0V on address match and then release it when the data is available.
BUSDATA_CLK_n =
    (P2 & SERPER_MATCH) #     // Pull the clock signal if a register of interest is being addressed in P2. 
    (CCKQ & BUSDATA_CLK_n) #  // State remains over P2 & P3.
    (!CCK & BUSDATA_CLK_n);   // State remains over P3 & P4.

// /OE for the pair of 245's gating the Paula from the data bus.
// Note that we drive data during P2, P3 and P4, not just the latter two, as it's necessary for early-read of DSKDATR.
// It doesn't seem to hurt anything else either, so far.
PAULA_BUSOE = 
//    RESET #                   // Closed when reset active.
    P1 #                      // Closed in P1.
    (P2 & SERPER_MATCH) #     // Closed if SERPER is addressed in P2.
    (P2 & IDLE_MATCH) #       // Closed if nothing is addressed in P2.
    (!CCK & PAULA_BUSOE) #    // State remains over P3 & P4.
    (!CCKQ & PAULA_BUSOE);    // Protect against glitch in transition P4->P1.

// DIR for the pair of 245s gating the Paula from the data bus.
// Note:
// when DIR pin is 0: (B) Paula -> (A) Bus
// when DIR pin is 1: (A) Bus -> (B) Paula
// But this is an inverted output, to make the equation manageable.
PAULA_BUSDIR_n =
    (P2 & DSKDATR_MATCH) #                          // Paula -> Bus when DSKDATR is addressed in P2.
    (P2 & !RGA8 & !RGA7 & !RGA6 & !RGA5 & RGA4) #   // Paula -> Bus when one of the other read registers is addressed in P2.
    (CCKQ & PAULA_BUSDIR_n) #                       // State remains over P2 & P3.
    (!CCK & PAULA_BUSDIR_n);                        // State remains over P3 & P4.

// Notify the MCU when registers of interest are being written.
// It won't be able to respond within this bus slot anyway, so the only thing that matters is that we do cause a rising flank
// so it can pick up the data word from the pair of 574s.
SERDAT_WRITTEN_n = P2 & SERDAT_MATCH;	
SERDATR_READ_n = P2 & SERDATR_MATCH;
SERPER_WRITTEN_n = P2 & SERPER_MATCH;
